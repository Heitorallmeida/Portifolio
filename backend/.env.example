# Example env for backend
# Preferred: set DATABASE_URL (postgres://user:pass@host:5432/dbname)
DATABASE_URL=postgres://postgres:psql@localhost:5432/portifolio

# Alternatively, individual connection vars (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=psql
DB_NAME=portifolio

# App
PORT=3000
NODE_ENV=development
